{
  "manifest_version": 3,
  "name": "IG Outreach Sender",
  "version": "0.1.0",
  "description": "Delivers queued DMs from your logged-in Instagram session, driven by your outreach backend. Throttled, capped, and stops on block.",
  "permissions": ["storage", "cookies", "alarms"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://i.instagram.com/*",
    "https://*.railway.app/*",
    "https://*.up.railway.app/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "IG Outreach Sender" }
}
